<?xml version="1.0"?>
<!-- vector0/model.sdf — DiffDrive listens to /vector0/cmd_vel -->
<sdf version="1.9">
<model name="vector0">
  <link name="base_link">
    <inertial>
      <mass>0.16</mass><pose>0.0075 0 -0.01 0 0 0</pose>
      <inertia><ixx>0.000156</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000094</iyy><iyz>0</iyz><izz>0.000225</izz></inertia>
    </inertial>
    <visual name="body_vis"><geometry><mesh><uri>model://vector/meshes/vector_body.dae</uri></mesh></geometry></visual>
    <collision name="body_col"><pose>0.0075 0 0.000 0 0 0</pose><geometry><box><size>0.070 0.043 0.035</size></box></geometry><surface><friction><ode><mu>0.5</mu><mu2>0.5</mu2></ode></friction></surface></collision>
  </link>
  <link name="head"><pose>0 0 0.027 0 0 0</pose>
    <inertial><mass>0.03</mass><inertia><ixx>0.000005</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000005</iyy><iyz>0</iyz><izz>0.000005</izz></inertia></inertial>
    <visual name="head_vis"><geometry><mesh><uri>model://vector/meshes/vector_head.dae</uri></mesh></geometry></visual>
    <collision name="head_col"><geometry><sphere><radius>0.02</radius></sphere></geometry></collision>
  </link>
  <joint name="head_joint" type="fixed"><parent>base_link</parent><child>head</child></joint>
  <link name="full_lift"><pose>0 0 0 0 0 0</pose>
    <inertial><mass>0.05</mass><inertia><ixx>0.000005</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.000005</iyy><iyz>0</iyz><izz>0.000005</izz></inertia></inertial>
    <visual name="lift_vis"><geometry><mesh><uri>model://vector/meshes/vector_lift.dae</uri></mesh></geometry></visual>
  </link>
  <joint name="lift_joint" type="fixed"><parent>base_link</parent><child>full_lift</child></joint>
  <link name="left_belt"><pose>0.00945 0.024 -0.01332 0 0 0</pose><visual name="vis"><geometry><mesh><uri>model://vector/meshes/cozmo_belt.dae</uri></mesh></geometry></visual></link>
  <joint name="left_belt_joint" type="fixed"><parent>base_link</parent><child>left_belt</child></joint>
  <link name="right_belt"><pose>0.00945 -0.024 -0.01332 0 0 0</pose><visual name="vis"><geometry><mesh><uri>model://vector/meshes/cozmo_belt.dae</uri></mesh></geometry></visual></link>
  <joint name="right_belt_joint" type="fixed"><parent>base_link</parent><child>right_belt</child></joint>
  <link name="front_left_wheel"><pose>0.03 0.024 -0.012 1.5708 0 0</pose>
    <inertial><mass>0.01</mass><inertia><ixx>0.0000009</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0000009</iyy><iyz>0</iyz><izz>0.0000017</izz></inertia></inertial>
    <collision name="col"><geometry><cylinder><radius>0.01314</radius><length>0.01167</length></cylinder></geometry><surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface></collision>
    <visual name="vis"><geometry><cylinder><radius>0.01314</radius><length>0.01167</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
  </link>
  <joint name="front_left_wheel_joint" type="revolute"><parent>base_link</parent><child>front_left_wheel</child><axis><xyz>0 0 -1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
  <link name="front_right_wheel"><pose>0.03 -0.024 -0.012 1.5708 0 0</pose>
    <inertial><mass>0.01</mass><inertia><ixx>0.0000009</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0000009</iyy><iyz>0</iyz><izz>0.0000017</izz></inertia></inertial>
    <collision name="col"><geometry><cylinder><radius>0.01314</radius><length>0.01167</length></cylinder></geometry><surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface></collision>
    <visual name="vis"><geometry><cylinder><radius>0.01314</radius><length>0.01167</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
  </link>
  <joint name="front_right_wheel_joint" type="revolute"><parent>base_link</parent><child>front_right_wheel</child><axis><xyz>0 0 -1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
  <link name="rear_left_wheel"><pose>-0.017 0.024 -0.01517 1.5708 0 0</pose>
    <inertial><mass>0.008</mass><inertia><ixx>0.0000004</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0000004</iyy><iyz>0</iyz><izz>0.0000008</izz></inertia></inertial>
    <collision name="col"><geometry><cylinder><radius>0.008995</radius><length>0.01167</length></cylinder></geometry><surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface></collision>
    <visual name="vis"><geometry><cylinder><radius>0.008995</radius><length>0.01167</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
  </link>
  <joint name="rear_left_wheel_joint" type="revolute"><parent>base_link</parent><child>rear_left_wheel</child><axis><xyz>0 0 -1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
  <link name="rear_right_wheel"><pose>-0.017 -0.024 -0.01517 1.5708 0 0</pose>
    <inertial><mass>0.008</mass><inertia><ixx>0.0000004</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.0000004</iyy><iyz>0</iyz><izz>0.0000008</izz></inertia></inertial>
    <collision name="col"><geometry><cylinder><radius>0.008995</radius><length>0.01167</length></cylinder></geometry><surface><friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction></surface></collision>
    <visual name="vis"><geometry><cylinder><radius>0.008995</radius><length>0.01167</length></cylinder></geometry><material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
  </link>
  <joint name="rear_right_wheel_joint" type="revolute"><parent>base_link</parent><child>rear_right_wheel</child><axis><xyz>0 0 -1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis></joint>
  <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
    <left_joint>front_left_wheel_joint</left_joint>
    <left_joint>rear_left_wheel_joint</left_joint>
    <right_joint>front_right_wheel_joint</right_joint>
    <right_joint>rear_right_wheel_joint</right_joint>
    <wheel_separation>0.048</wheel_separation>
    <wheel_radius>0.01314</wheel_radius>
    <max_linear_acceleration>5.0</max_linear_acceleration>
    <max_angular_acceleration>10.0</max_angular_acceleration>
    <topic>/vector0/cmd_vel</topic>
  </plugin>
  <plugin filename="gz-sim-pose-publisher-system" name="gz::sim::systems::PosePublisher">
    <publish_link_pose>false</publish_link_pose>
    <publish_model_pose>true</publish_model_pose>
    <update_frequency>50</update_frequency>
  </plugin>
</model>
</sdf>
